# Discord Developer Portal → Application → Bot → Token
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=

WELCOME_CHANNEL_ID=
VERIFIED_WELCOME_CHANNEL_ID=1501218975592484897
WELCOME_BANNER_URL=
WELCOME_MESSAGE=Welcome to **{server}**, {user}! We're glad you're here.

# Roles: Unverified → (captcha) → Waiting OR Verified
UNVERIFIED_ROLE_ID=
WAITING_ROOM_ROLE_ID=
VERIFIED_ROLE_ID=

VERIFICATION_CHANNEL_ID=
WAITING_ROOM_CHANNEL_ID=
VERIFICATION_BANNER_URL=

# false = unlocked (captcha → full access) | true = locked (captcha → waiting, code → full)
SERVER_LOCKED=false
# Legacy — shared codes are no longer used; each member gets a personal code via DM
# ACCESS_CODE=kovari

VERIFICATION_ENABLED=true
# Post verify/waiting panels on startup if missing (true | false)
AUTO_ENSURE_PANELS=true
ADMIN_ROLE_IDS=

# Optional: pre-set link protection (or use /links set in each channel)
# LINK_FULL_CHANNELS=channel_id_no_links
# LINK_MEDIUM_CHANNELS=channel_id_twitter_and_invites

# Role claim panel channel (optional — auto-post if roles configured)
ROLE_CLAIM_CHANNEL_ID=
ROLE_CLAIM_BANNER_URL=

OFFICIAL_LINKS_CHANNEL_ID=
OFFICIAL_X_URL=https://x.com/Kovarixyz
OFFICIAL_LINKS_BANNER_URL=

# X raids
# All bot action logs (raids, tickets, shop, giveaways, links, etc.)
BOT_LOG_CHANNEL_ID=1508160047157346415
# Raid join/verify/fail logs also post here (in addition to BOT_LOG_CHANNEL_ID)
RAID_LOG_CHANNEL_ID=
RAID_ANNOUNCE_CHANNEL_ID=
RAID_BANNER_URL=
RAID_PING_ROLE_ID=1508126086821843118

# Raid verification — recommended: export cookies to a JSON file (not multi-line .env)
TWITTER_COOKIES_FILE=data/twitter-cookies.json
# Or one-line JSON in .env: TWITTER_COOKIES=[{"name":"auth_token","value":"..."}]
TWITTER_COOKIES=
# Or: TWITTER_EMAIL= / TWITTER_PASSWORD= / TWITTER_USERNAME=
# Optional API fallback: TWITTER_BEARER_TOKEN=
# PYTHON_PATH=python

# Kovari tickets (or use /tickets setup)
TICKET_PANEL_CHANNEL_ID=
TICKET_STAFF_ROLE_IDS=
TICKET_BANNER_URL=

# Marketplace panel banner (optional)
SHOP_BANNER_URL=

# Points (defaults in data/points.json)
# POINTS_LOG_CHANNEL_ID=  (#points-earning — embed alerts when someone earns)
# POINTS_EARN_CHANNEL_IDS=id1,id2  (optional — omit to earn in any channel)
# POINTS_ALERT_REPLY=false  (set true to also reply under messages in chat)
# POINTS_MESSAGE=2
# POINTS_REACTION=1
# POINTS_RAID=25

# Easiest alert mirror (no extra API — other bot posts to source, Kovari reposts rebranded)
# ALERT_MIRROR_ENABLED=true
# Single pair (legacy):
# ALERT_MIRROR_SOURCE_CHANNEL_ID=private_ingest_channel_id
# ALERT_MIRROR_TARGET_CHANNEL_ID=public_alerts_channel_id
# Multiple pairs (source:target,source:target — one source can map to multiple targets):
# ALERT_MIRROR_PAIRS=1498472577532825660:1508169314644136026,1505177985026756628:1508169187481227274,1505178039460560997:1508169237137719457,1505178039460560997:1510452821072281741
# ALERT_MIRROR_BOT_IDS=other_bot_user_id
# ALERT_MIRROR_PING_ROLE_ID=
